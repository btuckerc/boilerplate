#!/bin/bash
# Managed by chezmoi - https://github.com/btuckerc/boilerplate
# Bash configuration file

# Source shared POSIX-compatible configuration
COMMON_SH="${XDG_CONFIG_HOME:-$HOME/.config}/shell/common.sh"
[ -f "$COMMON_SH" ] && . "$COMMON_SH"
unset COMMON_SH

# Safe fallback if common.sh is temporarily missing
export LOGFILE="${LOGFILE:-$HOME/.shellrc_log}"

# Load Ghostty's shell integration early so nested shells keep prompt marks.
if [ -n "${GHOSTTY_RESOURCES_DIR:-}" ] && [ -r "${GHOSTTY_RESOURCES_DIR}/shell-integration/bash/ghostty.bash" ]; then
    builtin source "${GHOSTTY_RESOURCES_DIR}/shell-integration/bash/ghostty.bash"
fi

# === Bash-Specific Configuration ===

{{- if eq .chezmoi.os "darwin" }}
# === macOS-specific Configuration ===

# Silence bash deprecation warning (macOS prefers zsh)
export BASH_SILENCE_DEPRECATION_WARNING=1

# Load Homebrew
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{- else if eq .chezmoi.os "linux" }}
# === Linux-specific Configuration ===

# Load Homebrew if installed (Linuxbrew)
# Commented out - not available on this system
# [ -d "/home/linuxbrew/.linuxbrew" ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Enable color support for ls
alias ls='ls --color=auto'

# Add Ruby gems to PATH (for user-installed gems)
export PATH="$PATH:$HOME/.local/share/gem/ruby/3.4.0/bin"

# Tmux session helper - attach to or create session named 'T'
t() {
    if [[ -z $TMUX ]]; then
        if tmux has-session -t T 2>/dev/null; then
            tmux attach-session -t T
        else
            tmux new-session -s T
        fi
    fi
}

# Load bash completion if available
if [ -r "/usr/share/bash-completion/bash_completion" ]; then
    . "/usr/share/bash-completion/bash_completion"
fi
{{- end }}

# === Mise activation ===
if command -v mise >/dev/null; then
    eval "$(mise activate bash)"
fi

# === Starship prompt ===
if command -v starship >/dev/null; then
    export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"
    eval "$(starship init bash)"
fi

# === Bash Options ===
for bash_opt in \
    checkwinsize \
    histappend \
    cmdhist \
    lithist \
    autocd \
    globstar \
    nocaseglob \
    cdspell \
    dirspell
do
    shopt -s "$bash_opt" 2>/dev/null || true
done
unset bash_opt

# === History Configuration ===
export HISTFILESIZE=1000000   # Increased from 10000 (match zsh)
export HISTSIZE=100000        # Increased from 5000 (closer to zsh)
export HISTCONTROL=ignoreboth:erasedups  # Ignore dupes and spaces, erase old dupes
export HISTTIMEFORMAT="%F %T "
history_sync_prompt='history -a; history -c; history -r'
if [ -n "${PROMPT_COMMAND:-}" ]; then
    case "$PROMPT_COMMAND" in
        "$history_sync_prompt"|"$history_sync_prompt; "*|*"; $history_sync_prompt"|*"; $history_sync_prompt; "*) ;;
        *)
            PROMPT_COMMAND="$history_sync_prompt; $PROMPT_COMMAND"
            ;;
    esac
else
    PROMPT_COMMAND="$history_sync_prompt"
fi
export PROMPT_COMMAND
unset history_sync_prompt

# === Bash-specific Functions ===

# Yazi wrapper (bash-specific for cd functionality)
y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    local cwd
    yazi "$@" --cwd-file="$tmp"
    cwd="$(command cat -- "$tmp")"
    if [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
        if [ -n "$TMUX" ]; then
            tmux refresh-client -c "$cwd"
        fi
    fi
    rm -f -- "$tmp"
}

# Logging
printf '%s: Bash shell loaded\n' "$(date)" >>"$LOGFILE" 2>/dev/null || true
