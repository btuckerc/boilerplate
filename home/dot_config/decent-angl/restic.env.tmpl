{{- $machineID := .decentangl.machine_id -}}
{{- $machine := get .decentangl.machines $machineID -}}
{{- $offsite := .decentangl.backup.offsite -}}
{{- $unattended := .decentangl.backup.unattended -}}
{{- $schedule := .decentangl.backup.schedule -}}
{{- $homeDir := .chezmoi.homeDir -}}
{{- $role := "" -}}
{{- if $machine -}}
{{-   $role = (get $machine "role") -}}
{{- end -}}
{{- $localPasswordFile := printf "%s/.local/share/decent-angl/secrets/restic.password" $homeDir -}}
{{- if $unattended -}}
{{-   $configuredPasswordFile := (get $unattended "local_password_file") -}}
{{-   if $configuredPasswordFile -}}
{{-     if hasPrefix "~/" $configuredPasswordFile -}}
{{-       $localPasswordFile = printf "%s/%s" $homeDir (trimPrefix "~/" $configuredPasswordFile) -}}
{{-     else -}}
{{-       $localPasswordFile = $configuredPasswordFile -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- $localRepo := "" -}}
{{- if eq $machineID "macmini" -}}
{{-   $localRepo = "/Users/admin/srv/restic/macmini" -}}
{{- else -}}
{{-   $localRepo = printf "sftp:admin@macmini.tail4d5aec.ts.net:/Users/admin/srv/restic/%s" $machineID -}}
{{- end -}}
{{- $offsiteEnabled := false -}}
{{- if $offsite -}}
{{-   $offsiteEnabled = (get $offsite "enabled") -}}
{{- end -}}
{{- $offsiteProvider := "" -}}
{{- $offsiteBWItem := "" -}}
{{- $offsiteURLBase := "" -}}
{{- if $offsite -}}
{{-   $offsiteProvider = (get $offsite "provider") -}}
{{-   $offsiteBWItem = (get $offsite "bw_item") -}}
{{-   $offsiteURLBase = (get $offsite "url_base") -}}
{{- end -}}
{{- $offsiteRepo := "" -}}
{{- if and $offsiteEnabled $offsiteURLBase -}}
{{-   $offsiteRepo = printf "rest:%s/%s" (trimSuffix "/" $offsiteURLBase) $machineID -}}
{{- end -}}
{{- $backupHour := 3 -}}
{{- $backupMinute := 15 -}}
{{- $restoreDay := 1 -}}
{{- $restoreHour := 4 -}}
{{- $restoreMinute := 15 -}}
{{- $forgetDay := 1 -}}
{{- $forgetHour := 4 -}}
{{- $forgetMinute := 45 -}}
{{- $checkDay := 1 -}}
{{- $checkHour := 5 -}}
{{- $checkMinute := 15 -}}
{{- $lockWaitSeconds := 7200 -}}
{{- if $schedule -}}
{{-   $lockWaitSeconds = (get $schedule "lock_wait_seconds") -}}
{{-   with (get $schedule "backup") -}}
{{-     $backupHour = (get . "hour") -}}
{{-     $backupMinute = (get . "minute") -}}
{{-   end -}}
{{-   with (get $schedule "restore_smoke") -}}
{{-     $restoreDay = (get . "day") -}}
{{-     $restoreHour = (get . "hour") -}}
{{-     $restoreMinute = (get . "minute") -}}
{{-   end -}}
{{-   with (get $schedule "forget_prune") -}}
{{-     $forgetDay = (get . "day") -}}
{{-     $forgetHour = (get . "hour") -}}
{{-     $forgetMinute = (get . "minute") -}}
{{-   end -}}
{{-   with (get $schedule "check") -}}
{{-     $checkDay = (get . "day") -}}
{{-     $checkHour = (get . "hour") -}}
{{-     $checkMinute = (get . "minute") -}}
{{-   end -}}
{{- end -}}
RESTIC_MACHINE_ID="{{ $machineID }}"
RESTIC_MACHINE_ROLE="{{ $role }}"
RESTIC_BW_ITEM="{{ .decentangl.secrets.restic_item }}"
RESTIC_PASSWORD_COMMAND="{{ $homeDir }}/.local/bin/bw-restic-password"
RESTIC_LOCAL_PASSWORD_FILE="{{ $localPasswordFile }}"
RESTIC_PASSWORD_FILE="{{ $localPasswordFile }}"
RESTIC_LOCAL_REPO="{{ $localRepo }}"
RESTIC_REPO="{{ $localRepo }}"
RESTIC_OFFSITE_ENABLED="{{ if $offsiteEnabled }}1{{ else }}0{{ end }}"
RESTIC_OFFSITE_PROVIDER="{{ $offsiteProvider }}"
RESTIC_OFFSITE_BW_ITEM="{{ $offsiteBWItem }}"
RESTIC_OFFSITE_URL_BASE="{{ $offsiteURLBase }}"
RESTIC_OFFSITE_REPO="{{ $offsiteRepo }}"
RESTIC_PATHS_FILE="{{ $homeDir }}/.config/decent-angl/restic/paths.txt"
RESTIC_EXCLUDES_FILE="{{ $homeDir }}/.config/decent-angl/restic/excludes.txt"
RESTIC_KEEP_DAILY="{{ .decentangl.backup.retention.daily }}"
RESTIC_KEEP_WEEKLY="{{ .decentangl.backup.retention.weekly }}"
RESTIC_KEEP_MONTHLY="{{ .decentangl.backup.retention.monthly }}"
RESTIC_KEEP_YEARLY="{{ .decentangl.backup.retention.yearly }}"
RESTIC_CHECK_READ_DATA_SUBSET="{{ .decentangl.backup.check_read_data_subset }}"
RESTIC_SCHEDULE_STATE_DIR="{{ $homeDir }}/.local/state/decent-angl/restic-scheduler"
RESTIC_SCHEDULE_LOG_DIR="{{ $homeDir }}/.local/state/decent-angl/restic-scheduler/logs"
RESTIC_SCHEDULE_LOCK_PATH="{{ $homeDir }}/.local/state/decent-angl/restic-scheduler/lock"
RESTIC_SCHEDULE_LOCK_WAIT_SECONDS="{{ $lockWaitSeconds }}"
RESTIC_SCHEDULE_BACKUP_HOUR="{{ $backupHour }}"
RESTIC_SCHEDULE_BACKUP_MINUTE="{{ $backupMinute }}"
RESTIC_SCHEDULE_RESTORE_DAY="{{ $restoreDay }}"
RESTIC_SCHEDULE_RESTORE_HOUR="{{ $restoreHour }}"
RESTIC_SCHEDULE_RESTORE_MINUTE="{{ $restoreMinute }}"
RESTIC_SCHEDULE_FORGET_DAY="{{ $forgetDay }}"
RESTIC_SCHEDULE_FORGET_HOUR="{{ $forgetHour }}"
RESTIC_SCHEDULE_FORGET_MINUTE="{{ $forgetMinute }}"
RESTIC_SCHEDULE_CHECK_DAY="{{ $checkDay }}"
RESTIC_SCHEDULE_CHECK_HOUR="{{ $checkHour }}"
RESTIC_SCHEDULE_CHECK_MINUTE="{{ $checkMinute }}"
