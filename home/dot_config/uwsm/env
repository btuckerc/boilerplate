# Changes require a restart to take effect.

export OMARCHY_PATH="${HOME}/.local/share/omarchy"

# Keep Omarchy and user-managed tools visible to UWSM-launched apps.
# Iterate from lowest to highest precedence because each directory is prepended.
prepend_path_dir() {
    path_dir="$1"
    [ -d "$path_dir" ] || return 0

    path_new="$path_dir"
    path_old_ifs="${IFS}"
    IFS=:
    for path_entry in ${PATH:-}; do
        [ -n "$path_entry" ] || continue
        [ "$path_entry" = "$path_dir" ] && continue
        path_new="${path_new}:$path_entry"
    done
    IFS="${path_old_ifs}"
    PATH="${path_new}"
}

for dir in "$HOME/.local/share/mise/shims" "$HOME/shims" "$OMARCHY_PATH/bin" "$HOME/.local/bin"; do
    prepend_path_dir "$dir"
done
export PATH
unset dir path_dir path_entry path_new path_old_ifs
unset -f prepend_path_dir 2>/dev/null || true

# Set default terminal and editor.
[ -r "$HOME/.config/uwsm/default" ] && . "$HOME/.config/uwsm/default"
