#!/bin/sh
set -eu

BW_BIN=""
for candidate in \
    "${BW_BIN:-}" \
    "$HOME/.local/share/mise/shims/bw" \
    "$HOME/.local/bin/bw" \
    "/opt/homebrew/bin/bw" \
    "/usr/local/bin/bw"
do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        BW_BIN="$candidate"
        break
    fi
done

if [ -z "$BW_BIN" ] && command -v bw >/dev/null 2>&1; then
    BW_BIN="$(command -v bw)"
fi

if [ -n "${RESTIC_PASSWORD:-}" ]; then
    printf '%s' "$RESTIC_PASSWORD"
    exit 0
fi

if [ -z "$BW_BIN" ]; then
    echo "bw CLI not found; install it and log in before using restic." >&2
    exit 1
fi

status="$("$BW_BIN" status 2>/dev/null | sed -n 's/.*"status":"\([^"]*\)".*/\1/p' | head -n1)"
status="${status:-unknown}"
case "$status" in
    unlocked)
        ;;
    unauthenticated)
        echo "bw is unauthenticated; run 'bw login' first." >&2
        exit 1
        ;;
    locked)
        echo "bw is locked; run 'export BW_SESSION=\$(bw unlock --raw)' first." >&2
        exit 1
        ;;
    *)
        echo "Unable to determine bw status." >&2
        exit 1
        ;;
esac

item="${RESTIC_BW_ITEM:-restic-decent-angl}"
password="$("$BW_BIN" get password "$item" 2>/dev/null || true)"
if [ -z "$password" ]; then
    echo "Vaultwarden item '$item' was not found; run 'restic-bootstrap-secret' after unlocking bw." >&2
    exit 1
fi
printf '%s' "$password"
