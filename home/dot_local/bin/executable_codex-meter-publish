#!/bin/sh
set -eu

self_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

for candidate in \
    "${self_dir}/codex-meter" \
    "${self_dir}/executable_codex-meter" \
    "$HOME/.local/bin/codex-meter" \
    "$(command -v codex-meter 2>/dev/null || true)"
do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        exec "$candidate" publish "$@"
    fi
done

echo "codex-meter helper not found." >&2
exit 1
