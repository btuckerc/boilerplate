#!/usr/bin/env python3

import argparse
import fcntl
import json
import os
import socket
import subprocess
import sys
import time
from pathlib import Path


DEBOUNCE_SECONDS = 0.15
IGNORE_SECONDS = 0.75


def eprint(*parts: object) -> None:
    print(*parts, file=sys.stderr)


def run_hyprctl(*args: str, json_output: bool = False) -> object:
    cmd = ["hyprctl"]
    if json_output:
        cmd.append("-j")
    cmd.extend(args)
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or f"hyprctl failed: {' '.join(cmd)}")
    if json_output:
        return json.loads(result.stdout)
    return result.stdout.strip()


def run_hyprctl_batch(commands: list[str]) -> None:
    if not commands:
        return
    batch = " ; ".join(commands)
    result = subprocess.run(["hyprctl", "--batch", batch], capture_output=True, text=True)
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip() or "hyprctl --batch failed")


def resolve_instance_signature() -> str:
    env_sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    if env_sig:
        return env_sig

    instances = run_hyprctl("instances")
    for line in str(instances).splitlines():
        line = line.strip()
        if line.startswith("instance ") and line.endswith(":"):
            return line[len("instance ") : -1]

    raise RuntimeError("could not resolve HYPRLAND_INSTANCE_SIGNATURE")


def socket2_path() -> Path:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    return Path(runtime_dir) / "hypr" / resolve_instance_signature() / ".socket2.sock"


def numeric_workspace_ids(workspaces: list[dict]) -> list[int]:
    ids: list[int] = []
    for workspace in workspaces:
        wid = workspace.get("id")
        name = workspace.get("name")
        if not isinstance(wid, int) or wid <= 0:
            continue
        if str(wid) != str(name):
            continue
        ids.append(wid)
    return sorted(set(ids))


def build_shift_map(workspaces: list[dict]) -> dict[int, int]:
    shift_map: dict[int, int] = {}
    for expected, wid in enumerate(numeric_workspace_ids(workspaces), start=1):
        if wid != expected:
            shift_map[wid] = expected
    return shift_map


def build_compaction_commands() -> tuple[list[str], dict[int, int]]:
    workspaces = run_hyprctl("workspaces", json_output=True)
    shift_map = build_shift_map(workspaces)
    if not shift_map:
        return [], {}

    clients = run_hyprctl("clients", json_output=True)
    monitors = run_hyprctl("monitors", json_output=True)

    commands: list[str] = []

    # Move windows from the highest shifted workspace down first.
    for client in sorted(
        clients,
        key=lambda item: int(item.get("workspace", {}).get("id", 0)),
        reverse=True,
    ):
        workspace = client.get("workspace") or {}
        source_id = workspace.get("id")
        if source_id not in shift_map:
            continue
        if not client.get("mapped", False):
            continue
        if client.get("pinned", False):
            continue

        address = client.get("address")
        target_id = shift_map[source_id]
        commands.append(f"dispatch movetoworkspacesilent {target_id},address:{address}")

    focused_monitor = next((monitor for monitor in monitors if monitor.get("focused")), None)
    focused_monitor_name = focused_monitor.get("name") if focused_monitor else None

    shifted_monitors: list[tuple[str, int, bool]] = []
    for monitor in monitors:
        active_workspace = monitor.get("activeWorkspace") or {}
        active_id = active_workspace.get("id")
        if active_id in shift_map:
            shifted_monitors.append((monitor["name"], shift_map[active_id], bool(monitor.get("focused"))))

    for monitor_name, target_id, is_focused in shifted_monitors:
        if is_focused:
            continue
        commands.append(f"dispatch focusmonitor {monitor_name}")
        commands.append(f"dispatch focusworkspaceoncurrentmonitor {target_id}")

    if focused_monitor_name:
        commands.append(f"dispatch focusmonitor {focused_monitor_name}")
        if focused_monitor:
            active_id = (focused_monitor.get("activeWorkspace") or {}).get("id")
            if active_id in shift_map:
                commands.append(f"dispatch focusworkspaceoncurrentmonitor {shift_map[active_id]}")

    return commands, shift_map


def compact_workspaces(verbose: bool = False) -> bool:
    commands, shift_map = build_compaction_commands()
    if not commands:
        if verbose:
            eprint("hyprland-workspace-compactd: no compaction needed")
        return False

    if verbose:
        eprint("hyprland-workspace-compactd: compacting", shift_map)
    run_hyprctl_batch(commands)
    return True


def acquire_lock() -> object:
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    lock_path = Path(runtime_dir) / "hyprland-workspace-compactd.lock"
    lock_file = open(lock_path, "w", encoding="utf-8")
    try:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        sys.exit(0)
    lock_file.write(f"{os.getpid()}\n")
    lock_file.flush()
    return lock_file


def daemon_loop(verbose: bool = False) -> None:
    acquire_lock()
    ignore_until = 0.0

    while True:
        try:
            path = socket2_path()
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
                sock.connect(str(path))
                stream = sock.makefile("r", encoding="utf-8", errors="replace")
                for raw_line in stream:
                    line = raw_line.strip()
                    if not line or not line.startswith("destroyworkspacev2>>"):
                        continue
                    now = time.monotonic()
                    if now < ignore_until:
                        continue

                    time.sleep(DEBOUNCE_SECONDS)
                    if compact_workspaces(verbose=verbose):
                        ignore_until = time.monotonic() + IGNORE_SECONDS
        except KeyboardInterrupt:
            return
        except Exception as exc:
            if verbose:
                eprint(f"hyprland-workspace-compactd: {exc}")
            time.sleep(1.0)


def main() -> int:
    parser = argparse.ArgumentParser(description="Compact Hyprland numeric workspaces when gaps appear.")
    parser.add_argument("--compact-now", action="store_true", help="Run one compaction pass immediately and exit.")
    parser.add_argument("--verbose", action="store_true", help="Log actions to stderr.")
    args = parser.parse_args()

    if args.compact_now:
        compact_workspaces(verbose=args.verbose)
        return 0

    daemon_loop(verbose=args.verbose)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
