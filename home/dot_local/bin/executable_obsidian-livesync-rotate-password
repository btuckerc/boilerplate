#!/usr/bin/env python3
import argparse
import base64
import json
import secrets
import shutil
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
import os
import shlex
import subprocess
import tomllib


def load_shell_config() -> dict[str, str]:
    config_path = Path(os.environ.get("OBSIDIAN_LIVESYNC_CONFIG_FILE", str(Path.home() / ".config/decent-angl/obsidian-livesync.env")))
    values: dict[str, str] = {}
    if not config_path.exists():
        return values
    for raw_line in config_path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in raw_line:
            continue
        key, value = raw_line.split("=", 1)
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
            value = value[1:-1]
        values[key.strip()] = value
    return values


def current_machine_id(config_values: dict[str, str]) -> str:
    if config_values.get("OBSIDIAN_LIVESYNC_MACHINE_ID"):
        return config_values["OBSIDIAN_LIVESYNC_MACHINE_ID"]
    chezmoi_toml = Path.home() / ".config/chezmoi/chezmoi.toml"
    if chezmoi_toml.exists():
        with chezmoi_toml.open("rb") as handle:
            data = tomllib.load(handle)
        return data.get("data", {}).get("decentangl", {}).get("machine_id", "unknown")
    return "unknown"


def parse_env_file(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in raw_line:
            continue
        key, value = raw_line.split("=", 1)
        values[key.strip()] = value.strip()
    return values


def write_env_value(path: Path, key: str, value: str) -> Path:
    backup = path.with_name(f"{path.name}.bak.{time.strftime('%Y%m%dT%H%M%S')}")
    shutil.copy2(path, backup)
    updated = False
    lines: list[str] = []
    for raw_line in path.read_text().splitlines():
        if raw_line.strip().startswith("#") or "=" not in raw_line:
            lines.append(raw_line)
            continue
        existing_key, _existing_value = raw_line.split("=", 1)
        if existing_key.strip() == key:
            lines.append(f"{key}={value}")
            updated = True
        else:
            lines.append(raw_line)
    if not updated:
        lines.append(f"{key}={value}")
    path.write_text("\n".join(lines) + "\n")
    return backup


def request_json(url: str, username: str, password: str, method: str = "GET", payload: dict | None = None) -> dict:
    request = urllib.request.Request(url, method=method)
    auth_header = base64.b64encode(f"{username}:{password}".encode()).decode()
    request.add_header("Authorization", f"Basic {auth_header}")
    request.add_header("Accept", "application/json")
    if payload is not None:
        body = json.dumps(payload).encode("utf-8")
        request.data = body
        request.add_header("Content-Type", "application/json")
    with urllib.request.urlopen(request, timeout=20) as response:
        data = response.read().decode("utf-8")
    if not data:
        return {}
    return json.loads(data)


def verify_database(url: str, username: str, password: str, database: str) -> None:
    database_url = f"{url.rstrip('/')}/{urllib.parse.quote(database, safe='')}"
    request_json(database_url, username, password)


def main() -> int:
    config_values = load_shell_config()
    parser = argparse.ArgumentParser(
        description="Rotate the dedicated Obsidian LiveSync sync-user password and update the env file."
    )
    parser.add_argument("--env-file", help="Path to the server env file.")
    parser.add_argument("--url", default="http://127.0.0.1:5984", help="Admin CouchDB URL.")
    parser.add_argument("--admin-user-key", default="COUCHDB_USER")
    parser.add_argument("--admin-password-key", default="COUCHDB_PASSWORD")
    parser.add_argument("--sync-user-key", default="WEAVEDWEB_SYNC_USER")
    parser.add_argument("--sync-password-key", default="WEAVEDWEB_SYNC_PASSWORD")
    parser.add_argument("--database-key", default="WEAVEDWEB_DB")
    parser.add_argument("--password", help="Explicit new sync password. Defaults to a random generated value.")
    parser.add_argument("--show-password", action="store_true", help="Print the new password to stdout.")
    parser.add_argument("--local-only", action="store_true", help="Do not auto-delegate to the server host.")
    args = parser.parse_args()

    server_machine_id = config_values.get("OBSIDIAN_LIVESYNC_SERVER_MACHINE_ID", "macmini")
    machine_id = current_machine_id(config_values)
    if not args.local_only and machine_id != server_machine_id:
        ssh_dest = config_values.get("OBSIDIAN_LIVESYNC_SERVER_SSH_DEST", "admin@macmini.tail4d5aec.ts.net")
        remote_cmd = ["$HOME/.local/bin/obsidian-livesync-rotate-password", "--local-only"]
        if args.env_file:
            remote_cmd.extend(["--env-file", args.env_file])
        if args.url:
            remote_cmd.extend(["--url", args.url])
        if args.password:
            remote_cmd.extend(["--password", args.password])
        if args.show_password:
            remote_cmd.append("--show-password")
        remote_cmd.extend([
            "--admin-user-key", args.admin_user_key,
            "--admin-password-key", args.admin_password_key,
            "--sync-user-key", args.sync_user_key,
            "--sync-password-key", args.sync_password_key,
            "--database-key", args.database_key,
        ])
        result = subprocess.run(
            ["ssh", ssh_dest, " ".join(shlex.quote(part) for part in remote_cmd)],
            check=False,
        )
        return result.returncode

    env_file = args.env_file or config_values.get("OBSIDIAN_LIVESYNC_SERVER_ENV_FILE")
    if not env_file:
        print("Env file is not set. Pass --env-file or configure OBSIDIAN_LIVESYNC_SERVER_ENV_FILE.", file=sys.stderr)
        return 1

    env_path = Path(env_file).expanduser()
    if not env_path.exists():
        print("Env file not found.", file=sys.stderr)
        return 1

    env_values = parse_env_file(env_path)
    missing = [
        key
        for key in [args.admin_user_key, args.admin_password_key, args.sync_user_key, args.sync_password_key, args.database_key]
        if not env_values.get(key)
    ]
    if missing:
        print(f"Missing env keys: {', '.join(missing)}", file=sys.stderr)
        return 1

    admin_user = env_values[args.admin_user_key]
    admin_password = env_values[args.admin_password_key]
    sync_user = env_values[args.sync_user_key]
    database = env_values[args.database_key]
    new_password = args.password or secrets.token_urlsafe(32)

    base_url = args.url.rstrip("/")
    user_doc_id = f"org.couchdb.user:{sync_user}"
    user_doc_url = f"{base_url}/_users/{urllib.parse.quote(user_doc_id, safe='')}"

    try:
        user_doc = request_json(user_doc_url, admin_user, admin_password)
    except urllib.error.HTTPError as exc:
        print(f"Failed to read CouchDB user document: {exc}", file=sys.stderr)
        return 1

    for key in ("derived_key", "iterations", "password_scheme", "salt", "password_sha", "pbkdf2_prf"):
        user_doc.pop(key, None)
    user_doc["password"] = new_password

    try:
        request_json(user_doc_url, admin_user, admin_password, method="PUT", payload=user_doc)
        verify_database(base_url, sync_user, new_password, database)
    except urllib.error.HTTPError as exc:
        print(f"Failed to rotate LiveSync password: {exc}", file=sys.stderr)
        return 1

    backup_path = write_env_value(env_path, args.sync_password_key, new_password)

    print("status=rotated")
    print(f"env_file={env_path}")
    print(f"env_backup={backup_path}")
    print(f"sync_user={sync_user}")
    print(f"database={database}")
    print(f"url={base_url}")
    if args.show_password:
        print(f"password={new_password}")
    else:
        print("password=hidden")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
