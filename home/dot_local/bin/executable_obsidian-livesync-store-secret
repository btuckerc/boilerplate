#!/bin/sh
set -eu

find_bin() {
    for candidate in "$@"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

CONFIG_FILE="${OBSIDIAN_LIVESYNC_CONFIG_FILE:-$HOME/.config/decent-angl/obsidian-livesync.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        -h|--help)
            cat <<'EOF'
Usage: obsidian-livesync-store-secret

Store or update the LiveSync backend credential and E2EE passphrase in
Vaultwarden. When run from a non-server machine, this command reads the
canonical backend credential from macmini over SSH and writes the item using
the local unlocked bw session.
EOF
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

MACHINE_ID="${OBSIDIAN_LIVESYNC_MACHINE_ID:-unknown}"
SERVER_MACHINE_ID="${OBSIDIAN_LIVESYNC_SERVER_MACHINE_ID:-macmini}"
SERVER_SSH_DEST="${OBSIDIAN_LIVESYNC_SERVER_SSH_DEST:-admin@macmini.tail4d5aec.ts.net}"
SERVER_HOME="${OBSIDIAN_LIVESYNC_SERVER_HOME:-/Users/admin}"
SERVER_URL="${OBSIDIAN_LIVESYNC_SERVER_URL:-https://notes.weavedweb.com}"
ENV_FILE="${OBSIDIAN_LIVESYNC_SERVER_ENV_FILE:-/Users/admin/homelab/obsidian-sync/.env}"
E2EE_FILE="${OBSIDIAN_LIVESYNC_E2EE_PASSPHRASE_FILE:-$HOME/.local/state/decent-angl/obsidian-livesync/weavedweb/weavedweb.e2ee.passphrase.txt}"
ITEM_NAME="${OBSIDIAN_LIVESYNC_BW_ITEM:-obsidian-livesync-weavedweb}"

BW_BIN="$(find_bin \
    "$HOME/.local/share/mise/shims/bw" \
    "$HOME/.local/bin/bw" \
    "/opt/homebrew/bin/bw" \
    "/usr/local/bin/bw" \
    "$(command -v bw 2>/dev/null || true)")"

if [ -z "${BW_BIN:-}" ] || ! command -v jq >/dev/null 2>&1; then
    echo "bw and jq are required." >&2
    exit 1
fi

status="$("$BW_BIN" status 2>/dev/null | sed -n 's/.*"status":"\([^"]*\)".*/\1/p' | head -n1)"
if [ "${status:-unknown}" != "unlocked" ]; then
    echo "bw must be unlocked first." >&2
    exit 1
fi

if [ ! -f "$E2EE_FILE" ]; then
    echo "LiveSync E2EE passphrase file not found: $E2EE_FILE" >&2
    exit 1
fi

if [ "$MACHINE_ID" = "$SERVER_MACHINE_ID" ]; then
    if [ ! -f "$ENV_FILE" ]; then
        echo "LiveSync env file not found: $ENV_FILE" >&2
        exit 1
    fi
    env_content="$(cat "$ENV_FILE")"
else
    env_content="$(ssh "$SERVER_SSH_DEST" "cat '$ENV_FILE'")"
fi

db_name="$(printf '%s\n' "$env_content" | sed -n 's/^WEAVEDWEB_DB=//p' | head -n1)"
sync_user="$(printf '%s\n' "$env_content" | sed -n 's/^WEAVEDWEB_SYNC_USER=//p' | head -n1)"
sync_password="$(printf '%s\n' "$env_content" | sed -n 's/^WEAVEDWEB_SYNC_PASSWORD=//p' | head -n1)"

if [ -z "$db_name" ] || [ -z "$sync_user" ] || [ -z "$sync_password" ]; then
    echo "Unable to parse LiveSync credential fields from $ENV_FILE" >&2
    exit 1
fi

e2ee_passphrase="$(tr -d '\n' <"$E2EE_FILE")"
if [ -z "$e2ee_passphrase" ]; then
    echo "LiveSync E2EE passphrase is empty." >&2
    exit 1
fi

notes="$(cat <<EOF
vault=weavedweb
server_url=$SERVER_URL
database=$db_name
e2ee_passphrase=$e2ee_passphrase
rotation_command=obsidian-livesync-refresh-bundle --rotate-password
setup_bundle_refresh=obsidian-livesync-refresh-bundle
EOF
)"

existing_id="$("$BW_BIN" list items --search "$ITEM_NAME" | jq -r --arg name "$ITEM_NAME" '.[] | select(.name == $name) | .id' | head -n1)"

if [ -n "${existing_id:-}" ]; then
    updated_payload="$("$BW_BIN" get item "$existing_id" | jq \
        --arg name "$ITEM_NAME" \
        --arg username "$sync_user" \
        --arg password "$sync_password" \
        --arg server_url "$SERVER_URL" \
        --arg notes "$notes" \
        '.name = $name
        | .type = 1
        | .notes = $notes
        | .login = (.login // {})
        | .login.username = $username
        | .login.password = $password
        | .login.uris = [{"uri": $server_url}]
        | .secureNote = null
        | .card = null
        | .identity = null')"
    "$BW_BIN" encode <<<"$updated_payload" | "$BW_BIN" edit item "$existing_id" >/dev/null
    printf 'updated:%s:%s\n' "$ITEM_NAME" "$existing_id"
    exit 0
fi

payload="$(jq -n \
    --arg name "$ITEM_NAME" \
    --arg username "$sync_user" \
    --arg password "$sync_password" \
    --arg server_url "$SERVER_URL" \
    --arg notes "$notes" \
    '{
      organizationId: null,
      folderId: null,
      type: 1,
      name: $name,
      notes: $notes,
      favorite: false,
      reprompt: 0,
      login: {
        username: $username,
        password: $password,
        totp: null,
        uris: [{uri: $server_url}]
      },
      secureNote: null,
      card: null,
      identity: null,
      fields: []
    }')"

created="$("$BW_BIN" encode <<<"$payload" | "$BW_BIN" create item)"
created_id="$(printf '%s' "$created" | jq -r '.id')"
printf 'created:%s:%s\n' "$ITEM_NAME" "$created_id"
