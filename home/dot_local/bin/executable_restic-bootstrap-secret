#!/bin/sh
set -eu

ITEM_NAME="${RESTIC_BW_ITEM:-restic-decent-angl}"

BW_BIN=""
for candidate in \
    "${BW_BIN:-}" \
    "$HOME/.local/share/mise/shims/bw" \
    "$HOME/.local/bin/bw" \
    "/opt/homebrew/bin/bw" \
    "/usr/local/bin/bw"
do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
        BW_BIN="$candidate"
        break
    fi
done

if [ -z "$BW_BIN" ] && command -v bw >/dev/null 2>&1; then
    BW_BIN="$(command -v bw)"
fi

if [ -z "$BW_BIN" ] || ! command -v jq >/dev/null 2>&1 || ! command -v openssl >/dev/null 2>&1; then
    echo "bw, jq, and openssl are required." >&2
    exit 1
fi

status="$("$BW_BIN" status 2>/dev/null | sed -n 's/.*"status":"\([^"]*\)".*/\1/p' | head -n1)"
status="${status:-unknown}"
if [ "$status" != "unlocked" ]; then
    echo "bw must be unlocked first." >&2
    exit 1
fi

existing_id="$("$BW_BIN" list items --search "$ITEM_NAME" | jq -r --arg name "$ITEM_NAME" '.[] | select(.name == $name) | .id' | head -n1)"
if [ -n "${existing_id:-}" ]; then
    echo "exists:$ITEM_NAME:$existing_id"
    exit 0
fi

password="$(openssl rand -base64 48 | tr -d '\n')"
payload="$(jq -n --arg name "$ITEM_NAME" --arg password "$password" --arg notes "Shared restic repository password for decent-angl." '{
  organizationId: null,
  folderId: null,
  type: 1,
  name: $name,
  notes: $notes,
  favorite: false,
  reprompt: 0,
  login: {
    username: "",
    password: $password,
    totp: null,
    uris: []
  },
  secureNote: null,
  card: null,
  identity: null,
  fields: []
}')"

created="$("$BW_BIN" encode <<<"$payload" | "$BW_BIN" create item)"
created_id="$(printf '%s' "$created" | jq -r '.id')"
echo "created:$ITEM_NAME:$created_id"
