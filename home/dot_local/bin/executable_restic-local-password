#!/bin/sh
set -eu

find_bin() {
    for candidate in "$@"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

stat_mode() {
    if stat -c '%a' "$1" >/dev/null 2>&1; then
        stat -c '%a' "$1"
        return 0
    fi
    stat -f '%Lp' "$1"
}

CONFIG_FILE="${RESTIC_CONFIG_FILE:-$HOME/.config/decent-angl/restic.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

PASSWORD_FILE="${RESTIC_LOCAL_PASSWORD_FILE:-${RESTIC_PASSWORD_FILE:-$HOME/.local/share/decent-angl/secrets/restic.password}}"
PASSWORD_DIR="$(dirname "$PASSWORD_FILE")"
BW_RESTIC_PASSWORD_BIN="$(find_bin \
    "$HOME/.local/bin/bw-restic-password" \
    "$(command -v bw-restic-password 2>/dev/null || true)")"

usage() {
    cat <<EOF
Usage: restic-local-password <status|sync|clear|print-path>

Commands:
  status      Show the machine-local restic password file state.
  sync        Fetch the shared restic password from Bitwarden and write the local file.
  clear       Remove the local file.
  print-path  Print the expected local file path.
EOF
}

command_name="${1:-status}"
case "$command_name" in
    status)
        exists=false
        mode='-'
        if [ -f "$PASSWORD_FILE" ]; then
            exists=true
            mode="$(stat_mode "$PASSWORD_FILE")"
        fi
        printf 'path=%s\n' "$PASSWORD_FILE"
        printf 'exists=%s\n' "$exists"
        printf 'mode=%s\n' "$mode"
        printf 'vault_item=%s\n' "${RESTIC_BW_ITEM:-restic-decent-angl}"
        printf 'manual_password_command=%s\n' "${RESTIC_PASSWORD_COMMAND:-$HOME/.local/bin/bw-restic-password}"
        ;;
    sync)
        umask 077
        password="${RESTIC_PASSWORD:-}"
        if [ -z "$password" ]; then
            if [ -z "${BW_RESTIC_PASSWORD_BIN:-}" ]; then
                echo "bw-restic-password helper not found." >&2
                exit 1
            fi
            password="$("$BW_RESTIC_PASSWORD_BIN")"
        fi
        if [ -z "$password" ]; then
            echo "Unable to resolve the restic password." >&2
            exit 1
        fi
        mkdir -p "$PASSWORD_DIR"
        chmod 700 "$PASSWORD_DIR"
        tmp_file="$(mktemp "$PASSWORD_DIR/restic.password.XXXXXX")"
        trap 'rm -f "$tmp_file"' EXIT INT TERM
        printf '%s' "$password" >"$tmp_file"
        chmod 600 "$tmp_file"
        mv "$tmp_file" "$PASSWORD_FILE"
        trap - EXIT INT TERM
        printf 'path=%s\n' "$PASSWORD_FILE"
        printf 'exists=true\n'
        printf 'mode=%s\n' "$(stat_mode "$PASSWORD_FILE")"
        ;;
    clear)
        rm -f "$PASSWORD_FILE"
        printf 'path=%s\n' "$PASSWORD_FILE"
        printf 'exists=false\n'
        ;;
    print-path)
        printf '%s\n' "$PASSWORD_FILE"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "Unknown subcommand: $command_name" >&2
        usage >&2
        exit 1
        ;;
esac
