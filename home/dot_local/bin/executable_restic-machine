#!/bin/sh
set -eu

find_bin() {
    for candidate in "$@"; do
        if [ -n "$candidate" ] && [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

CONFIG_FILE="${RESTIC_CONFIG_FILE:-$HOME/.config/decent-angl/restic.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

RESTIC_BIN="$(find_bin \
    "$HOME/.local/share/mise/shims/restic" \
    "$HOME/.local/bin/restic" \
    "/opt/homebrew/bin/restic" \
    "/usr/local/bin/restic" \
    "$(command -v restic 2>/dev/null || true)")"
RESTIC_TARGET_ENV_BIN="$(find_bin \
    "$HOME/.local/bin/restic-target-env" \
    "$(command -v restic-target-env 2>/dev/null || true)")"

if [ -z "${RESTIC_BIN:-}" ]; then
    echo "restic CLI not found." >&2
    exit 1
fi

if [ -z "${RESTIC_TARGET_ENV_BIN:-}" ]; then
    echo "restic-target-env helper not found." >&2
    exit 1
fi

REPO_TARGET="${RESTIC_REPO_TARGET:-local}"

if [ -n "${RESTIC_PASSWORD_FILE:-}" ] && [ -f "${RESTIC_PASSWORD_FILE:-}" ]; then
    export RESTIC_PASSWORD_FILE
elif [ -n "${RESTIC_PASSWORD_COMMAND:-}" ]; then
    export RESTIC_PASSWORD_COMMAND
else
    echo "Set RESTIC_PASSWORD_FILE or RESTIC_PASSWORD_COMMAND." >&2
    exit 1
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        --repo-target)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for --repo-target." >&2
                exit 1
            fi
            REPO_TARGET="$2"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

if [ "$#" -eq 0 ]; then
    cat <<EOF
Usage: restic-machine [--repo-target local|offsite] <restic-subcommand> [args...]

Runs the real restic CLI with this machine's rendered repository and password source.
Examples:
  restic-machine snapshots
  restic-machine --repo-target offsite snapshots
  restic-machine ls latest
  restic-machine find weavedweb
  restic-machine restore latest --target /tmp/restic-restore-smoke --include "$HOME/.config/decent-angl/restic.env"
  restic-machine restore latest --target /tmp/restore-test
EOF
    exit 1
fi

target_env="$("$RESTIC_TARGET_ENV_BIN" "$REPO_TARGET")" || exit 1
eval "$target_env"

exec "$RESTIC_BIN" -r "$RESTIC_TARGET_REPO" "$@"
