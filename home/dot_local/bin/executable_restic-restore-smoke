#!/bin/sh
set -eu

CONFIG_FILE="${RESTIC_CONFIG_FILE:-$HOME/.config/decent-angl/restic.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

RESTIC_MACHINE_BIN="${RESTIC_MACHINE_BIN:-$HOME/.local/bin/restic-machine}"
MACHINE_ID="${RESTIC_MACHINE_ID:-unknown}"
REPO_TARGET="${RESTIC_REPO_TARGET:-local}"
SMOKE_FILE="${RESTIC_SMOKE_RESTORE_FILE:-$HOME/.config/decent-angl/restic.env}"
TARGET=""
AUTO_TARGET=0
KEEP=0
PRINT_PLAN=0
CLEANUP_TARGET=0

cleanup() {
    if [ "$CLEANUP_TARGET" -eq 1 ] && [ -n "${TARGET:-}" ] && [ -d "$TARGET" ]; then
        rm -rf "$TARGET"
    fi
}
trap cleanup EXIT INT TERM

usage() {
    cat <<EOF
Usage: restic-restore-smoke [--print-plan] [--keep] [--file PATH] [--target DIR]
                           [--repo-target local|offsite]

Restores one known file from the latest snapshot and verifies it materializes under the target.
Defaults:
  file:   $HOME/.config/decent-angl/restic.env
  target: auto-generated temporary directory

Examples:
  restic-restore-smoke
  restic-restore-smoke --keep
  restic-restore-smoke --file "$HOME/.config/decent-angl/restic/paths.txt"
  restic-restore-smoke --target /tmp/restic-restore-smoke
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --file)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for --file." >&2
                exit 1
            fi
            SMOKE_FILE="$2"
            shift 2
            ;;
        --target)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for --target." >&2
                exit 1
            fi
            TARGET="$2"
            shift 2
            ;;
        --repo-target)
            if [ "$#" -lt 2 ]; then
                echo "Missing value for --repo-target." >&2
                exit 1
            fi
            REPO_TARGET="$2"
            shift 2
            ;;
        --keep)
            KEEP=1
            shift
            ;;
        --print-plan)
            PRINT_PLAN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
done

if [ ! -x "$RESTIC_MACHINE_BIN" ]; then
    echo "restic-machine helper not found: $RESTIC_MACHINE_BIN" >&2
    exit 1
fi

if [ ! -e "$SMOKE_FILE" ]; then
    echo "Smoke restore source path does not exist locally: $SMOKE_FILE" >&2
    exit 1
fi

if [ -z "$TARGET" ]; then
    AUTO_TARGET=1
    if [ "$PRINT_PLAN" -eq 1 ]; then
        TARGET="${TMPDIR:-/tmp}/restic-restore-smoke.<auto>"
    else
        TARGET="$(mktemp -d "${TMPDIR:-/tmp}/restic-restore-smoke.XXXXXX")"
        if [ "$KEEP" -ne 1 ]; then
            CLEANUP_TARGET=1
        fi
    fi
else
    if [ "$PRINT_PLAN" -ne 1 ]; then
        if [ -e "$TARGET" ] && [ ! -d "$TARGET" ]; then
            echo "Smoke restore target exists and is not a directory: $TARGET" >&2
            exit 1
        fi
        if [ -d "$TARGET" ] && find "$TARGET" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null | grep -q .; then
            echo "Smoke restore target must be empty: $TARGET" >&2
            exit 1
        fi
        mkdir -p "$TARGET"
    fi
fi

RESTORED_PATH="$TARGET$SMOKE_FILE"
KEEP_LABEL=false
AUTO_TARGET_LABEL=false
if [ "$KEEP" -eq 1 ]; then
    KEEP_LABEL=true
fi
if [ "$AUTO_TARGET" -eq 1 ]; then
    AUTO_TARGET_LABEL=true
fi

if [ "$PRINT_PLAN" -eq 1 ]; then
    printf 'machine_id=%s\n' "$MACHINE_ID"
    printf 'repo_target=%s\n' "$REPO_TARGET"
    printf 'smoke_file=%s\n' "$SMOKE_FILE"
    printf 'target=%s\n' "$TARGET"
    printf 'restored_path=%s\n' "$RESTORED_PATH"
    printf 'keep=%s\n' "$KEEP_LABEL"
    printf 'auto_target=%s\n' "$AUTO_TARGET_LABEL"
    exit 0
fi

"$RESTIC_MACHINE_BIN" --repo-target "$REPO_TARGET" restore latest --target "$TARGET" --include "$SMOKE_FILE"

if [ ! -e "$RESTORED_PATH" ]; then
    echo "Smoke restore failed; expected restored path not found: $RESTORED_PATH" >&2
    exit 1
fi

printf 'smoke_restore_target=%s\n' "$TARGET"
printf 'restored_path=%s\n' "$RESTORED_PATH"

if [ "$KEEP" -eq 1 ] || [ "$AUTO_TARGET" -ne 1 ]; then
    printf 'cleaned_up=false\n'
    exit 0
fi

printf 'cleaned_up=true\n'
