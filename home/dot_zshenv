#!/bin/zsh
# Managed by chezmoi - https://github.com/btuckerc/boilerplate
# Zsh environment configuration
# This file is sourced on all invocations of the shell (login, interactive, scripts)
# Keep this minimal - most config should go in .zshrc

# XDG Base Directory Specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Set ZDOTDIR for zsh config files
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# Starship prompt configuration
export STARSHIP_CONFIG="$HOME/.config/starship/starship.toml"

# Make Homebrew and system admin tools visible in non-interactive macOS shells.
if [ "$(uname -s)" = "Darwin" ]; then
    for dir in /opt/homebrew/bin /opt/homebrew/sbin /usr/local/bin /usr/local/sbin; do
        case ":$PATH:" in
            *":$dir:"*) ;;
            *) [ -d "$dir" ] && PATH="$dir:$PATH" ;;
        esac
    done
    export PATH
fi

# Keep user-managed bins and shims ahead of OS package-manager bins.
# Iterate from lowest to highest precedence because each directory is prepended.
prepend_path_dir() {
    path_dir="$1"
    [ -d "$path_dir" ] || return 0

    path_new="$path_dir"
    path_old_ifs="$IFS"
    IFS=:
    for path_entry in ${PATH:-}; do
        [ -n "$path_entry" ] || continue
        [ "$path_entry" = "$path_dir" ] && continue
        path_new="${path_new}:$path_entry"
    done
    IFS="$path_old_ifs"
    PATH="$path_new"
}

for dir in "$HOME/.local/share/mise/shims" "$HOME/shims"; do
    prepend_path_dir "$dir"
done
if [ "$(uname -s 2>/dev/null)" = "Linux" ]; then
    prepend_path_dir "$HOME/.local/share/omarchy/bin"
fi
prepend_path_dir "$HOME/.local/bin"
unset dir path_dir path_entry path_new path_old_ifs
unset -f prepend_path_dir 2>/dev/null || true

# Load Cargo environment if available
CARGODIR="$HOME/.cargo"
if [ -f "$CARGODIR/env" ]; then
    . "$CARGODIR/env"
fi
