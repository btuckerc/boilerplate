#!/usr/bin/env bash
set -euo pipefail

DOTFILES_REPO="${DOTFILES_REPO:-https://github.com/btuckerc/boilerplate.git}"
CHEZMOI_INSTALL_URL="${CHEZMOI_INSTALL_URL:-https://get.chezmoi.io}"
CHEZMOI_BIN_DIR="${CHEZMOI_BIN_DIR:-$HOME/.local/bin}"

export PATH="${CHEZMOI_BIN_DIR}:$PATH"

log() {
    printf '%s\n' "$*"
}

detect_local_source() {
    local src dir

    src="${BASH_SOURCE[0]:-$0}"
    [ -n "${src}" ] || return 1
    [ -f "${src}" ] || return 1

    dir="$(cd -- "$(dirname -- "${src}")" && pwd -P)"
    [ -f "${dir}/.chezmoiroot" ] || return 1

    printf '%s\n' "${dir}"
}

install_chezmoi() {
    if command -v chezmoi >/dev/null 2>&1; then
        return 0
    fi

    mkdir -p "${CHEZMOI_BIN_DIR}"
    log "Installing chezmoi to ${CHEZMOI_BIN_DIR}..."
    BINDIR="${CHEZMOI_BIN_DIR}" sh -c "$(curl -fsLS "${CHEZMOI_INSTALL_URL}")"
}

apply_dotfiles() {
    local local_source="${1:-}"

    if [ -n "${local_source}" ]; then
        log "Applying dotfiles from local checkout: ${local_source}"
        chezmoi init --source="${local_source}" --apply
        return
    fi

    log "Applying dotfiles from ${DOTFILES_REPO}"
    chezmoi init --apply "${DOTFILES_REPO}"
}

main() {
    local local_source=""

    if local_source="$(detect_local_source 2>/dev/null)"; then
        :
    else
        local_source=""
    fi

    log "Starting boilerplate bootstrap..."
    install_chezmoi
    apply_dotfiles "${local_source}"

    log ""
    log "Bootstrap complete. Restart your shell or run: exec ${SHELL:-/bin/sh}"
}

main "$@"
